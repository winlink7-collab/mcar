# mcar — Environment Variables
# Copy this file to .env and fill in your real values.
# .env is git-ignored and never committed.

# ============================================
# DATABASE (Cloudways → Application Access Details)
# ============================================
DB_HOST=localhost
DB_NAME=rdcbvmjwbe
DB_USER=rdcbvmjwbe
DB_PASS=your-cloudways-db-password-here
DB_CHARSET=utf8mb4

# ============================================
# EMAIL (where leads get sent)
# ============================================
MAIL_TO=vip@mcar.co.il
MAIL_FROM=noreply@mcar.co.il
MAIL_FROM_NAME=mcar

# SMTP (optional - leave empty to use built-in mail())
# Cloudways has built-in SMTP; or use SendGrid/Mailgun
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls

# ============================================
# reCAPTCHA v3 (https://www.google.com/recaptcha/admin)
# Leave empty to disable bot protection (not recommended for prod)
# ============================================
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# ============================================
# ADMIN PANEL
# ============================================
ADMIN_USER=admin
# Generate hash with: php -r "echo password_hash('your-password', PASSWORD_BCRYPT);"
ADMIN_PASS_HASH=$2y$10$REPLACE_WITH_REAL_BCRYPT_HASH

# ============================================
# APP
# ============================================
APP_ENV=production
APP_DEBUG=false
APP_URL=https://mcar.co.il
